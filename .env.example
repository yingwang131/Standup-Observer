# ===========================================
# Standup Observer - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git!
# ===========================================

# --- REQUIRED ---

# GitHub Personal Access Token
# How to get: https://github.com/settings/tokens
# Required scopes: repo (for private repos), read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# --- AI SUMMARIZATION (pick ONE) ---
# You need either AWS_BEARER_TOKEN_BEDROCK or ANTHROPIC_API_KEY
# for AI summarization. Without either, use `standup --no-ai`.

# Option 1: AWS Bedrock (Claude via AWS)
# How to get: AWS Console > Bedrock > API Keys, or contact your AWS admin
AWS_BEARER_TOKEN_BEDROCK=

# Option 2: Anthropic API (simpler if you don't have AWS)
# How to get: https://console.anthropic.com/
ANTHROPIC_API_KEY=


# --- OPTIONAL ---

# AWS region for Bedrock (default: us-east-1)
AWS_REGION=us-east-1

# Bedrock model ID (default: Claude Sonnet 4)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Outlook ICS calendar URL (can also be set in config.yaml)
# How to get: Outlook > Settings > Calendar > Shared calendars > Publish calendar
OUTLOOK_ICS_URL=
