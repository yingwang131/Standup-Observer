# ===========================================
# Standup Observer - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git!
# ===========================================

# GitHub Personal Access Token
# How to get: https://github.com/settings/tokens
# Required scopes: repo (for private repos), read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS Bedrock Token (for AI summarization)
# How to get: Contact your AWS admin or generate from AWS Console
# Required if using Claude via AWS Bedrock
AWS_BEARER_TOKEN_BEDROCK=your_aws_bedrock_token_here

# Jira API Token (optional)
# How to get: https://id.atlassian.com/manage-profile/security/api-tokens
# Leave empty to skip Jira integration
JIRA_API_TOKEN=
JIRA_EMAIL=your.email@company.com
